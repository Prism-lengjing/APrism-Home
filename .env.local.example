# Database
# 本地 SQLite 数据库路径
DATABASE_URL="file:./dev.db"

# NextAuth
# 用于 JWT 签名的密钥，部署前必须更换为随机字符串
AUTH_SECRET="your-secret-here"

# 管理员密码（仅用于 seed 脚本）
# ADMIN_PASSWORD="your-admin-password"

# Turso (可选，用于远程数据库)
# TURSO_URL="libsql://your-db.turso.io"
# TURSO_TOKEN="your-turso-token"

# Feishu (Lark) SMTP Configuration
# 飞书企业邮箱 SMTP 配置

# SMTP 服务器地址 (Feishu SMTP Server)
SMTP_HOST=smtp.feishu.cn

# 端口 (Port)
# 飞书通常推荐使用 SSL 加密端口 465
SMTP_PORT=465

# 您的飞书企业邮箱地址 (Your Feishu Email Address)
# 例如: your_name@your_company.com
SMTP_USER=your_name@your_company.com

# 您的飞书邮箱密码或授权码 (Your Password or App Password)
# 如果开启了二次验证，请使用生成的专用密码/授权码
SMTP_PASS=your_password_or_auth_code

# 启用安全连接 (SSL/TLS)
# 端口 465 必须设为 true
SMTP_SECURE=true

# 接收表单通知的邮箱 (Receiver Email)
# 默认发送给自己，也可以填其他邮箱
# 多个邮箱请用逗号分隔 (Multiple emails separated by commas)
CONTACT_EMAIL=receiver1@example.com,receiver2@example.com
